generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String             @id @default(cuid())
  slug        String             @unique
  name        String
  brand       String
  description String             @db.Text
  price       Decimal            @db.Decimal(10, 2)
  category    String
  status      ProductStatus      @default(DRAFT)
  sizes       String[]
  sizePricing Json?
  /// Legacy aggregate; sum of sizeStocks + variant stocks is authoritative for inventory
  quantity    Int                @default(0)
  consignment Boolean            @default(false)
  images      ProductImage[]
  sizeStocks  ProductSizeStock[]
  variants    ProductVariant[]
  lineItems   OrderLineItem[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([category])
}

/// Optional color variants of a product. A product with zero variants behaves
/// exactly as before (uses Product.images, Product.sizeStocks, Product.price).
/// A product with one or more variants supersedes those for display: PDP shows
/// a swatch row and the selected variant's images/sizes/stock/price.
model ProductVariant {
  id           String                    @id @default(cuid())
  productId    String
  product      Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName    String
  /// Hex color (e.g. "#ECE5D4") used for the storefront swatch. Optional — falls back to a labeled chip.
  colorHex     String?
  /// Optional price override; null = use product.price
  price        Decimal?                  @db.Decimal(10, 2)
  displayOrder Int                       @default(0)
  images       ProductVariantImage[]
  sizeStocks   ProductVariantSizeStock[]
  lineItems    OrderLineItem[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@unique([productId, colorName])
  @@index([productId])
}

model ProductVariantImage {
  id           String         @id @default(cuid())
  variantId    String
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url          String
  displayOrder Int            @default(0)

  @@index([variantId])
}

model ProductVariantSizeStock {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  size      String
  quantity  Int            @default(0)

  @@unique([variantId, size])
  @@index([variantId])
}

model ProductSizeStock {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  quantity  Int     @default(0)

  @@unique([productId, size])
  @@index([productId])
}

model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  displayOrder Int     @default(0)

  @@index([productId])
}

model WtfImage {
  id           String   @id @default(cuid())
  url          String
  displayOrder Int      @default(0)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([displayOrder])
  @@index([featured])
}

model CustomerProfile {
  clerkUserId         String   @id
  email               String
  welcomeDiscountUsed Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([email])
}

model PromoCode {
  id               String    @id @default(cuid())
  code             String    @unique
  type             PromoType
  /// PERCENT: 0–100 whole order; FIXED: USD off order subtotal
  value            Decimal     @db.Decimal(10, 2)
  active           Boolean     @default(true)
  expiresAt        DateTime?
  maxRedemptions   Int?
  perCustomerLimit Int?
  minSubtotal      Decimal?    @db.Decimal(10, 2)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  orders           Order[]
}

model Order {
  id                     String          @id @default(cuid())
  status                 OrderStatus     @default(PENDING)
  subtotal               Decimal         @db.Decimal(10, 2)
  discountTotal          Decimal         @default(0) @db.Decimal(10, 2)
  total                  Decimal         @db.Decimal(10, 2)
  email                  String?
  stripeSessionId        String?         @unique
  stripePaymentIntentId  String?         @unique
  clerkUserId            String?
  supplierOrderReference String?
  supplierOrderedAt      DateTime?
  supplierShippedAt      DateTime?
  deliveredAt            DateTime?
  shippingCarrier        String?
  trackingNumber         String?
  fulfillmentNotes       String?         @db.Text
  welcomeDiscountApplied Boolean         @default(false)
  promoCodeId            String?
  promo                  PromoCode?      @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  lineItems              OrderLineItem[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([clerkUserId])
}

model OrderLineItem {
  id           String          @id @default(cuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  /// Color variant (null when the product has no variants)
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  /// Snapshot of the color name at purchase time (preserved even if variant is deleted)
  variantLabel String?
  size         String
  quantity     Int
  unitPrice    Decimal         @db.Decimal(10, 2)
  name         String
  brand        String

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Submission {
  id           String           @id @default(cuid())
  name         String
  email        String
  phone        String?
  itemName     String
  brand        String
  description  String           @db.Text
  askingPrice  Decimal?         @db.Decimal(10, 2)
  condition    String
  imageUrls    String[]
  status       SubmissionStatus @default(PENDING)
  adminNotes   String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status])
}

enum PromoType {
  PERCENT
  FIXED
}

enum SubmissionStatus {
  PENDING
  REVIEWING
  ACCEPTED_BUY
  ACCEPTED_CONSIGN
  DECLINED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  SUPPLIER_ORDERED
  SUPPLIER_SHIPPED
  DELIVERED
  CANCELLED
}
